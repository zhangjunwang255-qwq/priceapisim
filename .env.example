# Railway 环境变量（本地测试用）
# 复制此文件为 .env 并填入实际值

# Railway PostgreSQL（部署后自动注入，无需手动设置）
# DATABASE_URL=postgresql://...

# 天勤模拟账户（必填）
TQ_ACCOUNT=你的快期账号
TQ_PASSWORD=你的快期密码

# 订阅的合约代码（逗号分隔）
# 主连合约（推荐）：自动跟踪主力
SYMBOLS=KQ.m@GFEX.PT,KQ.m@GFEX.PD
# 也可指定具体合约，如：
# SYMBOLS=GFEX.PT2606,GFEX.PD2606

# 端口（Railway 自动设置，无需手动）
# PORT=8080
